{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/main/packages/tauri-cli/schema.json",
  "productName": "白石 BaiShi",
  "version": "0.1.4",
  "identifier": "studio.baishi.desktop",
  "build": {
    "frontendDist": "../front",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "",
    "beforeDevCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "白石 BaiShi",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://localhost:* https:; img-src 'self' data: blob: asset: https://asset.localhost https:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg",
      "msi",
      "nsis"
    ],
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../front/assets"
    ],
    "category": "GraphicsDesign",
    "shortDescription": "水墨生图桌面应用",
    "longDescription": "白石 BaiShi — 为创作者而生的水墨画风格桌面生图应用，支持在线API+本地推理。"
  }
}
